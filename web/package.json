{
  "name": "run-houston-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Run Houston Web Frontend - Marketing website and admin dashboard",
  "scripts": {
    "dev": "npm run dev:main",
    "dev:main": "vite --config vite.config.main.ts --port 5173",
    "dev:admin": "vite --config vite.config.admin.ts --port 5174 --open admin/index.html",
    "dev:both": "concurrently \"npm run dev:main\" \"npm run dev:admin\"",
    "build": "npm run build:main && npm run build:admin",
    "build:main": "tsc -b && vite build --config vite.config.main.ts",
    "build:admin": "tsc -b && vite build --config vite.config.admin.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "papaparse": "^5.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "ts-jest": "^29.4.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "4.5.5"
  }
}
